<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Get CRUD</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css">
</head>
<body>
    <div class="container mt-5">
        <h2>List Users</h2>
        <a href="/crud" class="btn btn-success mb-3">Create new User</a>
        <table class="table table-bordered table-hover">
            <thead>
                <tr>
                    <th>Email</th>
                    <th>First Name</th>
                    <th>Last Name</th>
                    <th>Address</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <% for(let i=0; i < datalist.length; i++) { %>
                <tr>
                    <td><%= datalist[i].email %></td>
                    <td><%= datalist[i].firstName %></td>
                    <td><%= datalist[i].lastName %></td>
                    <td><%= datalist[i].address %></td>
                    <td>
                        <a href="/edit-crud?id=<%= datalist[i].id %>" class="btn btn-warning btn-sm">Edit</a>
                        <a href="/delete-crud?id=<%= datalist[i].id %>" class="btn btn-danger btn-sm">Delete</a>
                    </td>
                </tr>
                <% } %>
            </tbody>
        </table>
    </div>
</body>
</html>
